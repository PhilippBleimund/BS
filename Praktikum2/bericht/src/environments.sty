\newcommand\Chapter[2]{%
  \chapter[#1]{%
    #1\hfill\makebox[0pt][l]{} {\footnotesize\itshape#2}
  }
}

\newcommand\Section[2]{%
  \section[#1]{%
    #1\hfill\makebox[0pt][l]{} {\footnotesize\itshape#2}
  }
}

\newcommand\Subsection[2]{%
  \subsection[#1]{%
    #1\hfill\makebox[0pt][l]{} {\footnotesize\itshape#2}
  }
}