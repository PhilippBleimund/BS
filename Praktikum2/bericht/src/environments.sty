\makeatletter
\pgfdeclareshape{asymcloud}{
  \inheritsavedanchors[from=ellipse]
  \inheritanchorborder[from=ellipse]
  \inheritanchor[from=ellipse]{center}
  \inheritanchor[from=ellipse]{north}
  \inheritanchor[from=ellipse]{south}
  \inheritanchor[from=ellipse]{west}
  \inheritanchor[from=ellipse]{east}
  \inheritanchor[from=ellipse]{north west}
  \inheritanchor[from=ellipse]{north east}
  \inheritanchor[from=ellipse]{south west}
  \inheritanchor[from=ellipse]{south east}

  \anchor{center}{\pgfpoint{0cm}{0cm}}

  \backgroundpath{
    \pgfpathmoveto{\pgfpoint{-0.6cm}{-0.7cm}}
    \pgfpathcurveto{\pgfpoint{-1.3cm}{-1.1cm}}{\pgfpoint{-1.7cm}{0.3cm}}{\pgfpoint{-0.7cm}{0.3cm}}
    \pgfpathcurveto{\pgfpoint{-0.6cm}{0.7cm}}{\pgfpoint{-0.2cm}{0.9cm}}{\pgfpoint{0.2cm}{0.7cm}}
    \pgfpathcurveto{\pgfpoint{0.5cm}{1.5cm}}{\pgfpoint{1.6cm}{1.3cm}}{\pgfpoint{1.7cm}{0.5cm}}
    \pgfpathcurveto{\pgfpoint{2.5cm}{0.4cm}}{\pgfpoint{2.2cm}{-1cm}}{\pgfpoint{1.4cm}{-0.6cm}}
    \pgfpathcurveto{\pgfpoint{1.2cm}{-1cm}}{\pgfpoint{0.8cm}{-1cm}}{\pgfpoint{0.5cm}{-0.7cm}}
    \pgfpathcurveto{\pgfpoint{0.1cm}{-1cm}}{\pgfpoint{-0.3cm}{-1cm}}{\pgfpoint{-0.6cm}{-0.7cm}}
    \pgfpathclose
    \pgfusepath{stroke} % Draw the shape
  }
}
