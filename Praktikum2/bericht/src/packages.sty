% =========
% Footnotes
% =========
\usepackage{footnote}
% perpage -> resets counter after each page
% hang    -> sets footnote flush with margin (makes \footnotemargin possible)
% bottom  -> footnotes appear below bottom floats
% stable  -> footnotes in headers get formatted correctly
% multiple-> multiple footnotes at the same "word" get separated by a comma
\usepackage[perpage, hang, bottom, stable, multiple]{footmisc}
\setlength\footnotemargin{10pt}
% \tablefootnote in a table to get working footnotes
\usepackage{tablefootnote}

% \FloatBarrier to create a line which floats (figure, etc.) can not pass
\usepackage[section]{placeins}

% =========
% References
% =========
% create hyperlinks throughout the documents
\usepackage[ngerman]{hyperref}
% when using \cref{1,2,3} \cref{1,,2,,3} can be used to name the references individually
\usepackage[ngerman, nameinlink]{cleveref}
\creflabelformat{equation}{#2\textup{#1}#3}


